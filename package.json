{
  "name": "your-project-name",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    // Development server with Vite
    "dev": "vite",
    // Production build with Vite
    "build": "vite build",
    // Development build for debugging
    "build:dev": "vite build --mode development",
    // Linting using ESLint
    "lint": "eslint .",
    // Automated testing with Jest
    "test": "jest",
    // Install Husky Git hooks
    "prepare": "husky install",
    // Trigger build after dependencies installation
    "postinstall": "npm run build",
    // Run lint and build after tests
    "posttest": "npm run lint && npm run build"
  },
  "dependencies": {
    // Production dependencies
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    // Add more production dependencies as needed
  },
  "devDependencies": {
    // Development dependencies
    "@eslint/js": "^9.9.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    // Additional development dependencies
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "husky": "^7.0.0",
    "jest": "^27.5.1",
    "lint-staged": "^12.0.0",
    "prettier": "^2.5.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1"
    // Add more dev dependencies here
  },
  "husky": {
    // Configure pre-commit hook with lint-staged
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    // Automatically format and lint staged files
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "scripts": {
    // Development server with Vite
    "dev": "vite",
    // Production build with Vite
    "build": "vite build",
    // Development build for debugging
    "build:dev": "vite build --mode development",
    // Linting using ESLint
    "lint": "eslint .",
    // Automated testing with Jest
    "test": "jest",
    // Install Husky Git hooks
    "prepare": "husky install",
    // Trigger build after dependencies installation
    "postinstall": "npm run build",
    // Run lint and build after tests
    "posttest": "npm run lint && npm run build",
    // Automatically install missing dependencies
    "install:deps": "npm install",
    // Automatically update dependencies and lock file
    "update:deps": "npm update"
  }
}
